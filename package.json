{
  "name": "brick-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "verify:xcode": "zsh ./scripts/verify-xcode-ready.sh",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "release:macos": "pnpm build && tauri build --bundles app,dmg",
    "release:github": "pnpm build && tauri build --bundles dmg",
    "release:macos:verify-signing": "zsh ./scripts/verify-macos-signing-env.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "~2.10.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.0",
    "recharts": "^2.12.0",
    "framer-motion": "^11.0.0",
    "dayjs": "^1.11.10"
  },
  "devDependencies": {
    "@tauri-apps/cli": "~2.10.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
